# --- Public dataset: keep ranking / composition inputs (*.json), drop generated/heavy blobs ---
# Downloaded / trimmed clips (video)
public/data/clips/

# Whisper / caption pipeline output
public/data/transcripts/

# Per-actor clip review manifests (regenerated by clip-review / find_clips scripts)
public/data/**/*-clips.json

# Poster / still images next to JSON (not Remotion template art)
public/data/**/*.jpg
public/data/**/*.jpeg
public/data/**/*.png
public/data/**/*.webp

# Root clip-studio manifest (paths into media/raw — not composition source)
clips.json

# Template & brand assets under public/assets (binary; paths stay in source)
public/assets/**/*.jpg
public/assets/**/*.jpeg
public/assets/**/*.png
public/assets/**/*.webp
public/assets/**/*.gif
public/assets/**/*.mp3
public/assets/**/*.wav
public/assets/**/*.m4a
public/assets/**/*.aac
public/assets/**/*.ogg
public/assets/**/*.ttf
public/assets/**/*.otf
public/assets/**/*.woff
public/assets/**/*.woff2

# Video (final renders, source raws, exports anywhere in repo)
**/*.mp4
**/*.webm
**/*.mov
**/*.m4v
**/*.mkv
**/*.avi

# Audio
**/*.mp3
**/*.wav
**/*.aac
**/*.m4a
**/*.ogg
**/*.flac

# Git internals (if ever indexed from repo root)
.git/
